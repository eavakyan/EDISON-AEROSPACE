# Edison API — environment variables.
# Copy to /etc/edison-api.env on the VPS (chmod 600, owner = edison-api user).

# ---- Server ----
PORT=8787
HOST=127.0.0.1
NODE_ENV=production

# Public origin of the marketing site. Used to build verification URLs and
# the post-verify redirect. No trailing slash.
PUBLIC_ORIGIN=https://edison.aero

# Cookie domain. Use the bare domain so cookies cover www. and apex.
COOKIE_DOMAIN=.edison.aero

# ---- Secrets ----
# Used to sign verification tokens. Generate with: openssl rand -hex 64
TOKEN_SECRET=replace_me_with_64_hex_chars

# ---- Resend (email provider) ----
# Sign up at https://resend.com, verify the sending subdomain
# (resend.edison.aero), generate an API key. Sender address must live
# on the verified subdomain; Reply-To can be any address.
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="Edison Aerospace <noreply@resend.edison.aero>"
EMAIL_REPLY_TO=info@edison.aero

# Where lead notification emails go on successful verification.
LEAD_NOTIFY_EMAIL=gene@vugaenterprises.com

# ---- Storage ----
# Directory for the leads JSONL file and the consumed-tokens file.
# Must be writable by the edison-api user. systemd unit creates it.
DATA_DIR=/var/lib/edison-api

# ---- Cookie ----
COOKIE_NAME=edison_investor
COOKIE_TTL_DAYS=30
TOKEN_TTL_MINUTES=30
